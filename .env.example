# HOW TO GET YOUR BLOG ID:
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Navigate to APIs & Services > Credentials
# 3. Click "+ Create Credentials" > "API key"
# 4. Restrict the API key to "Blogger API v3" only
# 5. Call this URL in your browser (replace YOUR-BLOG-URL and YOUR_API_KEY):
#    https://www.googleapis.com/blogger/v3/blogs/byurl?url=https://YOUR-BLOG-URL&key=YOUR_API_KEY
# 6. Copy the "id" field from the returned JSON response

# HOW TO GET CLIENT_SECRETS.JSON:
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create a new project or select an existing one
# 3. Enable the Blogger API v3: https://console.cloud.google.com/apis/library/blogger.googleapis.com
# 4. Navigate to APIs & Services > Credentials
# 5. Click "+ Create Credentials" > "OAuth 2.0 Client ID"
# 6. Choose "Desktop app" as the application type
# 7. Download the generated JSON file
# 8. Rename it to "client_secrets.json"
# 9. Place it in the same directory as this script

BLOG_ID=your_blog_id_here
CLIENT_SECRETS_FILE=client_secrets.json